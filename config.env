# ==============================================================
# PLIK: config.env — szablon konfiguracji InfraCtrl Orders
# Skopiuj jako .env i uzupełnij wartości:
#   cp config.env .env && nano .env
# NIE COMMITUJ pliku .env do repozytorium!
# ==============================================================

# ── AWS ────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_KEY_NAME=infractrl-key
AWS_KEY_FILE=~/.ssh/infractrl-key.pem
AWS_INSTANCE_TYPE=t3.small
AWS_AMI_ID=ami-0e9e6ba6d3f8b2be9

# ── GRAFANA ────────────────────────────────────────────────────
# ZMIEŃ TO HASŁO przed deployem!
GRAFANA_PASSWORD=changeme

# ── PORTY APLIKACJI ────────────────────────────────────────────
PORT_CLIENT_A=3001
PORT_CLIENT_B=3002
PORT_ADMIN=3003
PORT_PRODUCTION=3004
PORT_API=8000
PORT_GRAFANA=3000
PORT_PROMETHEUS=9090
PORT_LOKI=3100

# ── RETENCJA DANYCH ────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=720h

# ── KONFIGURACJA KLIENTA A ─────────────────────────────────────
CLIENT_A_ID=A
CLIENT_A_COLOR=#0ea5e9
CLIENT_A_REGION=EU-WEST-1

# ── KONFIGURACJA KLIENTA B ─────────────────────────────────────
CLIENT_B_ID=B
CLIENT_B_COLOR=#8b5cf6
CLIENT_B_REGION=US-EAST-1

# ==============================================================
# OPCJONALNE: OGRANICZENIE DOSTĘPU PO IP
# Puste = dostęp publiczny. Format: 1.2.3.4/32
# ==============================================================
ALLOWED_IP_CLIENT_A=
ALLOWED_IP_CLIENT_B=
ALLOWED_IP_ADMIN=
ALLOWED_IP_PRODUCTION=
ALLOWED_IP_MONITORING=
ALLOWED_SSH_IP=

# ── AUTO-STOP EC2 ──────────────────────────────────────────────
AUTOSTOP_ENABLED=true
AUTOSTOP_TIMEZONE=Europe/Warsaw
AUTOSTOP_STOP_HOUR=18
AUTOSTOP_START_HOUR=7
AUTOSTOP_DAYS=MON-FRI

# ── API URL dla klientów A i B ─────────────────────────────────
# Lokalnie: http://localhost:8000
# Na AWS: http://<EC2-PUBLIC-IP>:8000  (uzupełnij po deploy)
API_URL_CLIENTS=http://localhost:8000

# ── GITHUB CONTAINER REGISTRY (GHCR) ──────────────────────────
# Obrazy Dockera budowane są przez GitHub Actions i pushowane do GHCR.
# Serwer EC2 tylko pobiera gotowe obrazy — nie buduje ich samodzielnie.
#
# GHCR_OWNER  — GitHub login lub nazwa organizacji (małe litery!)
#               np. jan-kowalski  lub  moja-firma
# GHCR_TOKEN  — Personal Access Token z uprawnieniem read:packages
#               Wygeneruj: https://github.com/settings/tokens/new
#               Wystarczy Classic token z zaznaczonym read:packages
GHCR_OWNER=twoj-github-login
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
